# .env.example — safe to commit
# Copy to .env.local and fill in real values — NEVER commit .env.local

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=floodsense_lk
POSTGRES_USER=floodsense_user
POSTGRES_PASSWORD=changeme_in_local
POSTGRES_DSN=postgresql+asyncpg://floodsense_user:changeme_in_local@localhost:5433/floodsense_lk

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── MCP Server (mcp-lk-river-intel must be running in SSE mode) ───────────────
MCP_SERVER_URL=http://localhost:8765

# ── LLM — single model for all agents ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-04-17
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=1024

# ── Alert Delivery (Twilio) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Disable all delivery locally — never send real messages during development
ENABLE_WHATSAPP_ALERTS=false
ENABLE_SMS_ALERTS=false
ENABLE_EMAIL_ALERTS=false

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ALERT_SALT=replace_with_random_32_char_string
ADMIN_API_KEY=replace_with_random_32_char_key

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_INTERVAL_SECONDS=1800
BASELINE_RECOMPUTE_DAY=sunday

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8002
LOG_LEVEL=DEBUG
